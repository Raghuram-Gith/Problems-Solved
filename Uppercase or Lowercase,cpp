#include <iostream>
#include <string>

using namespace std;

int main() {
    string s;
    // Note: cin >> s only reads until the first whitespace. 
    // Use getline(cin, s) if the input contains spaces.
    cin >> s; 

    int lower = 0;
    int upper = 0;

    for (char ch : s) {
        if (ch >= 'a' && ch <= 'z') {
            lower |= (1 << (ch - 'a'));
        } 
        else if (ch >= 'A' && ch <= 'Z') {
            upper |= (1 << (ch - 'A'));
        }
    }

    if (lower == (1 << 26) - 1 && upper == (1 << 26) - 1) {
        cout << "yes";
    } else {
        cout << "no";
    }

    return 0;
}
